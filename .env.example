# Copy this file to `.env` and paste your own keys. `.env` is git-ignored.
#
#     cp .env.example .env
#     $EDITOR .env
#
# The repo runs fully WITHOUT any key: every figure in RESEARCH.md and RESULTS.md is
# reproduced from the snapshots bundled in data/raw/. Keys are only needed to pull
# fresher data than the bundled gas day.

# GIE AGSI+ / ALSI — gas storage and LNG terminals.
# Free account, key never expires: https://agsi.gie.eu/account
# The same key works for both agsi.gie.eu and alsi.gie.eu. Sent as the `x-key` header.
AGSI_KEY=

# Eurostat  — no key required.
# ENTSOG    — no key required.
